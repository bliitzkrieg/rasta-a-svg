  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "24.10.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.15.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "4.0.7"
  }
